{
  "name": "frontend-e2e-tests",
  "version": "1.0.0",
  "private": true,
  "description": "Black-box Selenium WebDriver E2E suite for the frontend app",
  "scripts": {
    "test": "mocha --config .mocharc.json",
    "test:headed": "cross-env HEADLESS=false mocha --config .mocharc.json",
    "test:auth": "mocha --config .mocharc.json --grep \"Authentication\"",
    "test:navigation": "mocha --config .mocharc.json --grep \"Navigation\""
  },
  "dependencies": {
    "chromedriver": "^147.0.0",
    "dotenv": "^16.4.7",
    "selenium-webdriver": "^4.27.0"
  },
  "devDependencies": {
    "chai": "^4.5.0",
    "cross-env": "^7.0.3",
    "mocha": "^11.1.0"
  }
}
